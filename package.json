{
  "name": "bucataria-mea",
  "version": "1.0.5",
  "description": "Asistent culinar personal cu Chef AI",
  "main": "electron/main.js",
  "author": "Alexandru",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win --x64",
    "electron:preview": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "firebase": "^12.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "ro.bucatariamea.app",
    "productName": "Bucataria Mea",
    "copyright": "Alexandru",
    "directories": {
      "output": "dist-electron"
    },
    "publish": {
      "provider": "github",
      "owner": "kalu1990",
      "repo": "retetar"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "python-embed",
        "to": "python-embed",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "retetar_api.py",
        "to": "app/retetar_api.py"
      },
      {
        "from": "data",
        "to": "app/data",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "Bucataria.Mea.Setup.${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bucataria Mea",
      "deleteAppDataOnUninstall": true,
      "runAfterFinish": false
    },
    "asarUnpack": [
      "electron/**/*",
      "assets/**/*"
    ]
  }
}
